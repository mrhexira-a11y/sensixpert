rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'sensixpertadmin@gmail.com' ||
        request.auth.token.email == 'admin@sensixpert.com' ||
        request.auth.token.email == 'mrhexira@gmail.com'
      );
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isAdmin();
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /payments/{paymentId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /notifications/{notifId} {
      allow read, write, delete: if isAdmin();
      allow read: if isAuthenticated();
    }

    match /support_chats/{chatId} {
      allow read, write, delete: if isAdmin();
      allow read, write: if isAuthenticated() && request.auth.uid == chatId;

      match /messages/{messageId} {
        allow read, write, delete: if isAdmin();
        allow read, write: if isAuthenticated() && request.auth.uid == chatId;
      }
    }

    match /config/{docId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated();
    }

    match /app_config/{docId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated();
    }

    // ── Refer & Earn Collections ──

    // Referral codes (document ID = code like "SX7A3K")
    match /referrals/{code} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Referral logs (tracks who referred whom)
    match /referral_logs/{logId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Wallets (document ID = userId)
    match /wallets/{userId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated();
    }

    // Withdrawal requests
    match /withdrawals/{withdrawalId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

  }
}
